  <!--
       resvg build integration: invokes cargo against the resvg C-API crate
       before our C++ compiles, producing a static lib we then link.
       Cargo handles its own incremental build, so no-op rebuilds are fast.
  -->
  <Target Name="ResvgPreflight" BeforeTargets="ResvgBuild">
    <Message Condition="!Exists('$(ResvgCApiDir)\Cargo.toml')" Importance="High" Text="resvg sources not found at $(ResvgSourceDir); cloning..." />
    <Exec Condition="!Exists('$(ResvgCApiDir)\Cargo.toml')" Command="git clone --depth 1 https://github.com/linebender/resvg.git &quot;$(ResvgSourceDir)&quot;" />
    <Error Condition="!Exists('$(ResvgCApiDir)\Cargo.toml')" Text="Failed to obtain resvg sources at $(ResvgSourceDir). Verify git is on PATH and the destination directory is empty (or set ResvgSourceDir to an existing checkout)." />
    <Exec Command="cargo --version" ConsoleToMSBuild="true" IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="_ResvgCargoExitCode" />
    </Exec>
    <Error Condition="'$(_ResvgCargoExitCode)' != '0'" Text="cargo not found on PATH. Install the Rust toolchain from https://rustup.rs/ before building." />
    <Exec Command="rustup target add $(ResvgRustTarget)" IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="_ResvgTargetAddExitCode" />
    </Exec>
    <Exec Condition="'$(_ResvgTargetAddExitCode)' != '0'" Command="rustup target remove $(ResvgRustTarget)" IgnoreExitCode="true" />
    <Exec Condition="'$(_ResvgTargetAddExitCode)' != '0'" Command="rustup target add $(ResvgRustTarget)" />
  </Target>
  <Target Name="ResvgBuild" BeforeTargets="ClCompile">
    <Message Importance="High" Text="Building resvg C-API ($(ResvgRustTarget), release)..." />
    <Exec Command="set &quot;CARGO_TARGET_DIR=$(ResvgCargoTargetDir)&quot; &amp;&amp; call &quot;$(VCInstallDir)Auxiliary\Build\vcvars64.bat&quot; &gt;NUL &amp;&amp; cargo build --release --target $(ResvgRustTarget)" WorkingDirectory="$(ResvgCApiDir)" />
    <Error Condition="!Exists('$(ResvgStaticLib)')" Text="cargo finished but $(ResvgStaticLib) was not produced. Verify resvg's Cargo.toml has crate-type = [&quot;staticlib&quot;]." />
  </Target>
