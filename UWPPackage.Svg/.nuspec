        <file src="..\ARM64\Release\UWPPackage.Svg\UWPPackage.Svg.winmd" target="lib/native/Release/ARM64"/>
        <file src="..\ARM64\Release\UWPPackage.Svg\UWPPackage.Svg.dll" target="lib/native/Release/ARM64"/>
