<Page
    x:Class="UWPExample.TablePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:UWPPackage"
    xmlns:local="using:UWPExample"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded"
    mc:Ignorable="d">

    <Grid RowSpacing="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <muxc:InfoBar
            Title="This component is currently for demo only and is not in Package yet!"
            IsClosable="False"
            IsOpen="True"
            Severity="Warning" />

        <local:ControlExample
            Grid.Row="1"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            HeaderText="Table demo">
            <essential:Table
                x:Name="DemoTable"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />
            <local:ControlExample.Output>
                <TextBlock MinWidth="75">
                    <Run Text="Fps: " />
                    <Run Text="{x:Bind DemoTable.Fps, Mode=OneWay}" />
                </TextBlock>
            </local:ControlExample.Output>
        </local:ControlExample>

    </Grid>
</Page>
