<SwapChainPanel
    x:Class="WinUI3Package.Table"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinUI3Package"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    VerticalAlignment="Stretch"
    PointerWheelChanged="SwapChainPanel_PointerWheelChanged"
    SizeChanged="SwapChainPanel_SizeChanged"
    mc:Ignorable="d">

    <Border BorderBrush="White" BorderThickness="0.5" />

    <Button
        x:Name="Button"
        HorizontalAlignment="Center"
        Click="ClickHandler">
        Click Me
    </Button>

    <primitives:ScrollBar
        x:Name="VerticalScrollBar"
        HorizontalAlignment="Right"
        VerticalAlignment="Stretch"
        IndicatorMode="MouseIndicator"
        Maximum="100"
        Minimum="0"
        ValueChanged="VerticalScrollBar_ValueChanged"
        ViewportSize="30"
        Value="0" />

    <primitives:ScrollBar
        x:Name="HorizontalScrollBar"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Bottom"
        IndicatorMode="MouseIndicator"
        Maximum="100"
        Minimum="0"
        Orientation="Horizontal"
        ValueChanged="HorizontalScrollBar_ValueChanged"
        ViewportSize="30"
        Value="0" />
</SwapChainPanel>
