namespace PackageRoot
{
    /*
        Multiple converter container,
        converting values from the output of the last converter to the input of the next converter
    */
    [default_interface]
    [contentproperty("Converters")]
    runtimeclass ConverterGroup : WinUINamespace.UI.Xaml.Data.IValueConverter
    {
        ConverterGroup();

        Windows.Foundation.Collections.IVector<WinUINamespace.UI.Xaml.Data.IValueConverter> Converters;
    }
}
