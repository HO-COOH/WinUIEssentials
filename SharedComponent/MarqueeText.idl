namespace PackageRoot
{
    enum MarqueeBehavior
    {
        // The text flows across the screen from start to finish.
        Ticker,
        // As the text flows across the screen a duplicate follows.
        Looping,
        //The text bounces back and forth across the screen.
        Bouncing
    };

    enum MarqueeDirection
    {
        Left,
        Right,
        Up,
        Down
    };

    [bindable]
    [default_interface]
    unsealed runtimeclass MarqueeText : WinUINamespace.UI.Xaml.Controls.Control
    {
        MarqueeText();
        
        Double Speed;
        static WinUINamespace.UI.Xaml.DependencyProperty SpeedProperty{ get; };

        WinUINamespace.UI.Xaml.Media.Animation.RepeatBehavior RepeatBehavior;
        static WinUINamespace.UI.Xaml.DependencyProperty RepeatBehaviorProperty{ get; };

        MarqueeBehavior Behavior;
        static WinUINamespace.UI.Xaml.DependencyProperty BehaviorProperty{ get; };

        MarqueeDirection Direction;
        static WinUINamespace.UI.Xaml.DependencyProperty DirectionProperty{ get; };

        String Text;
        static WinUINamespace.UI.Xaml.DependencyProperty TextProperty{ get; };

        Boolean PauseOnHover;
        static WinUINamespace.UI.Xaml.DependencyProperty PauseOnHoverProperty{ get; };

        Double IntervalSpace;
        static WinUINamespace.UI.Xaml.DependencyProperty IntervalSpaceProperty{ get; };

        void Pause();
        void Resume();
        void Reset();
    }
}
