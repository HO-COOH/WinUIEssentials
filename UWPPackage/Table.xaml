<SwapChainPanel
    x:Class="UWPPackage.Table"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UWPPackage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:Windows.UI.Xaml.Controls.Primitives"
    VerticalAlignment="Stretch"
    ActualThemeChanged="Table_ActualThemeChanged"
    CompositionScaleChanged="SwapChainPanel_CompositionScaleChanged"
    DoubleTapped="SwapChainPanel_DoubleTapped"
    Loaded="Table_Loaded"
    PointerExited="SwapChainPanel_PointerExited"
    PointerMoved="SwapChainPanel_PointerMoved"
    PointerPressed="SwapChainPanel_PointerPressed"
    PointerReleased="SwapChainPanel_PointerReleased"
    PointerWheelChanged="SwapChainPanel_PointerWheelChanged"
    SizeChanged="SwapChainPanel_SizeChanged"
    Unloaded="Table_Unloaded"
    mc:Ignorable="d">
    <SwapChainPanel.Style>
        <Style TargetType="local:Table">
            <Setter Property="PointerOverBackground" Value="{ThemeResource ControlFillColorSecondary}" />
            <Setter Property="HorizontalLineColor" Value="{ThemeResource DividerStrokeColorDefault}" />
            <Setter Property="VerticalLineColor" Value="{ThemeResource DividerStrokeColorDefault}" />
            <Setter Property="FontFamily" Value="XamlAutoFontFamily" />
            <Setter Property="ContentFontSize" Value="14" />
            <Setter Property="HeaderFontSize" Value="18" />
            <Setter Property="ContentPadding" Value="6" />
        </Style>
    </SwapChainPanel.Style>

    <Canvas x:Name="ControlsOverlay" />
    <Canvas x:Name="HeaderControlsOverlay" />

    <primitives:ScrollBar
        x:Name="VerticalScrollBar"
        HorizontalAlignment="Right"
        VerticalAlignment="Stretch"
        IndicatorMode="MouseIndicator"
        ValueChanged="VerticalScrollBar_ValueChanged" />

    <primitives:ScrollBar
        x:Name="HorizontalScrollBar"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Bottom"
        IndicatorMode="MouseIndicator"
        Orientation="Horizontal"
        SmallChange="50"
        ValueChanged="HorizontalScrollBar_ValueChanged" />
</SwapChainPanel>
