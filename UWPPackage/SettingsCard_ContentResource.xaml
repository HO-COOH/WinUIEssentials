<ResourceDictionary
    x:Class="UWPPackage.SettingsCard_ContentResource"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UWPPackage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Style BasedOn="{StaticResource DefaultToggleSwitchStyle}" TargetType="ToggleSwitch">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style BasedOn="{StaticResource DefaultSliderStyle}" TargetType="Slider">
        <Setter Property="MinWidth" Value="{ThemeResource SettingsCardContentMinWidth}" />
    </Style>
    <Style BasedOn="{StaticResource DefaultComboBoxStyle}" TargetType="ComboBox">
        <Setter Property="MinWidth" Value="{ThemeResource SettingsCardContentMinWidth}" />
    </Style>
    <Style BasedOn="{StaticResource DefaultTextBoxStyle}" TargetType="TextBox">
        <Setter Property="MinWidth" Value="{ThemeResource SettingsCardContentMinWidth}" />
    </Style>
</ResourceDictionary>
