<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <id>WinUIEssential.WinUI3.Svg</id>
        <version>1.0.0</version>
        <title>WinUIEssential.WinUI3.Svg</title>
        <authors>Peter</authors>
        <owners></owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>SVG image source for WinUI3, backed by resvg. Provides WinUI3Package.Svg.SvgImageSource as a drop-in replacement for the built-in SvgImageSource with support for raw SVG strings, fragment-aware URI loading, and uniform rasterization to a target pixel size.</description>
        <icon>assets\MainLogo.png</icon>
        <dependencies>
            <group targetFramework="native">
                <dependency id="Microsoft.WindowsAppSDK" version="1.4.231115000"/>
                <dependency id="Microsoft.Windows.CppWinRT" version="2.0.230706.1"/>
                <dependency id="Microsoft.Windows.ImplementationLibrary" version="1.0.240803.1"/>
            </group>
        </dependencies>
        <license type="expression">MIT</license>
        <readme>docs\README.md</readme>
        <projectUrl>https://github.com/HO-COOH/WinUIEssentials</projectUrl>
        <tags>c++ cpp was winui3 winui svg resvg cpp20</tags>
        <repository type="git" url="https://github.com/HO-COOH/WinUIEssentials"/>
    </metadata>
    <files>
        <!--build/native-->
        <file src="WinUIEssential.WinUI3.Svg.targets" target="build/native"/>

        <!--lib/native-->
        <file src="..\x64\Debug\WinUI3Package.Svg\WinUI3Package.Svg.winmd" target="lib/native/Debug/x64"/>
        <file src="..\x64\Debug\WinUI3Package.Svg\WinUI3Package.Svg.dll" target="lib/native/Debug/x64"/>
        <file src="..\x64\Debug\WinUI3Package.Svg\WinUI3Package.Svg.pri" target="lib/native/Debug/x64"/>
        <file src="..\x64\Debug\WinUI3Package.Svg\WinUI3Package.Svg.pdb" target="lib/native/Debug/x64"/>

        <file src="..\ARM64\Debug\WinUI3Package.Svg\WinUI3Package.Svg.winmd" target="lib/native/Debug/ARM64"/>
        <file src="..\ARM64\Debug\WinUI3Package.Svg\WinUI3Package.Svg.dll" target="lib/native/Debug/ARM64"/>
        <file src="..\ARM64\Debug\WinUI3Package.Svg\WinUI3Package.Svg.pri" target="lib/native/Debug/ARM64"/>
        <file src="..\ARM64\Debug\WinUI3Package.Svg\WinUI3Package.Svg.pdb" target="lib/native/Debug/ARM64"/>

        <file src="..\x64\Release\WinUI3Package.Svg\WinUI3Package.Svg.winmd" target="lib/native/Release/x64"/>
        <file src="..\x64\Release\WinUI3Package.Svg\WinUI3Package.Svg.dll" target="lib/native/Release/x64"/>
        <file src="..\x64\Release\WinUI3Package.Svg\WinUI3Package.Svg.pri" target="lib/native/Release/x64"/>
        <file src="..\x64\Release\WinUI3Package.Svg\WinUI3Package.Svg.pdb" target="lib/native/Release/x64"/>

        <file src="..\ARM64\Release\WinUI3Package.Svg\WinUI3Package.Svg.winmd" target="lib/native/Release/ARM64"/>
        <file src="..\ARM64\Release\WinUI3Package.Svg\WinUI3Package.Svg.dll" target="lib/native/Release/ARM64"/>
        <file src="..\ARM64\Release\WinUI3Package.Svg\WinUI3Package.Svg.pri" target="lib/native/Release/ARM64"/>
        <file src="..\ARM64\Release\WinUI3Package.Svg\WinUI3Package.Svg.pdb" target="lib/native/Release/ARM64"/>

        <!-- Meta -->
        <file src="..\MainLogo.png" target="assets\"/>
        <file src="..\LICENSE.txt" target="licenses\"/>
        <file src="..\README.md" target="docs\"/>
    </files>
</package>
