    <StackPanel Style="{StaticResource ControlExamplesStackPanelStyle}">
        <local:ControlExample HeaderText="Win32 titlebar">
            <Button x:Name="CreateWin32Window" Click="CreateWin32Window_Click">Click to create window with win32 titlebar with automatic dark mode</Button>
            <local:ControlExample.Xaml>
                <local:CodeSource>
                    <local:CodeSource.Code>
                        <x:String xml:space="preserve">&lt;essential:WindowEx
    x:Class=&quot;WinUI3Example.Win32TitleBar&quot;
    xmlns=&quot;http://schemas.microsoft.com/winfx/2006/xaml/presentation&quot;
    xmlns:x=&quot;http://schemas.microsoft.com/winfx/2006/xaml&quot;
    xmlns:local=&quot;using:WinUI3Example&quot;
    xmlns:essential=&quot;using:WinUI3Package&quot;
    xmlns:d=&quot;http://schemas.microsoft.com/expression/blend/2008&quot;
    xmlns:mc=&quot;http://schemas.openxmlformats.org/markup-compatibility/2006&quot;
    TitleBarAutoDarkMode=&quot;True&quot;
    mc:Ignorable=&quot;d&quot;&gt;

&lt;/essential:WindowEx&gt;</x:String>
                    </local:CodeSource.Code>
                </local:CodeSource>
            </local:ControlExample.Xaml>
        </local:ControlExample>

        <local:ControlExample HeaderText="Custom titlebar content using WindowEx.NonClientRegionKind">
            <Button x:Name="CreateCustomWindow" Click="CreateCustomWindow_Click">Click to create window with custom titlebar</Button>
            <local:ControlExample.Xaml>
                <local:CodeSource>
                    <local:CodeSource.Code>
                        <x:String xml:space="preserve">&lt;Window
    x:Class=&quot;WinUI3Example.CustomTitleBar&quot;
    xmlns=&quot;http://schemas.microsoft.com/winfx/2006/xaml/presentation&quot;
    xmlns:x=&quot;http://schemas.microsoft.com/winfx/2006/xaml&quot;
    xmlns:d=&quot;http://schemas.microsoft.com/expression/blend/2008&quot;
    xmlns:essential=&quot;using:WinUI3Package&quot;
    xmlns:mc=&quot;http://schemas.openxmlformats.org/markup-compatibility/2006&quot;
    mc:Ignorable=&quot;d&quot;&gt;

    &lt;Window.SystemBackdrop&gt;
        &lt;MicaBackdrop /&gt;
    &lt;/Window.SystemBackdrop&gt;

    &lt;Grid&gt;
        &lt;Grid.RowDefinitions&gt;
            &lt;RowDefinition Height=&quot;48&quot; /&gt;
            &lt;RowDefinition /&gt;
        &lt;/Grid.RowDefinitions&gt;

        &lt;essential:WindowCaptionButtonThemeWorkaround Window=&quot;{x:Bind}&quot; /&gt;
        &lt;Grid&gt;
            &lt;Grid.ColumnDefinitions&gt;
                &lt;!--  Left padding  --&gt;
                &lt;ColumnDefinition Width=&quot;10&quot; /&gt;

                &lt;!--  Icon column  --&gt;
                &lt;ColumnDefinition Width=&quot;Auto&quot; /&gt;

                &lt;!--  Title column  --&gt;
                &lt;ColumnDefinition Width=&quot;Auto&quot; /&gt;

                &lt;!--  drag area  --&gt;
                &lt;ColumnDefinition Width=&quot;*&quot; /&gt;

                &lt;!--  AutoSuggestBox column  --&gt;
                &lt;ColumnDefinition Width=&quot;4*&quot; MinWidth=&quot;220&quot; /&gt;

                &lt;!--  drag area  --&gt;
                &lt;ColumnDefinition Width=&quot;*&quot; MinWidth=&quot;48&quot; /&gt;

                &lt;!--  PersonPicture control  --&gt;
                &lt;ColumnDefinition Width=&quot;Auto&quot; /&gt;

                &lt;!--  drag area  --&gt;
                &lt;ColumnDefinition Width=&quot;140&quot; /&gt;
            &lt;/Grid.ColumnDefinitions&gt;
            &lt;Image
                Grid.Column=&quot;1&quot;
                Width=&quot;16&quot;
                Height=&quot;16&quot;
                Margin=&quot;8,0,16,0&quot;
                Source=&quot;ms-appx:///Assets/StoreLogo.png&quot; /&gt;
            &lt;TextBlock
                Grid.Column=&quot;2&quot;
                VerticalAlignment=&quot;Center&quot;
                Style=&quot;{StaticResource CaptionTextBlockStyle}&quot;
                Text=&quot;App title&quot; /&gt;
            &lt;AutoSuggestBox
                Grid.Column=&quot;4&quot;
                MaxWidth=&quot;600&quot;
                VerticalAlignment=&quot;Center&quot;
                essential:WindowEx.NonClientRegionKind=&quot;Passthrough&quot;
                PlaceholderText=&quot;Search&quot;
                QueryIcon=&quot;Find&quot; /&gt;
            &lt;StackPanel
                Grid.Column=&quot;6&quot;
                Margin=&quot;0,0,16,0&quot;
                essential:WindowEx.NonClientRegionKind=&quot;Passthrough&quot;
                Orientation=&quot;Horizontal&quot;
                Spacing=&quot;10&quot;&gt;
                &lt;ToggleButton&gt;Button on titlebar&lt;/ToggleButton&gt;
                &lt;PersonPicture Height=&quot;32&quot; PointerPressed=&quot;PersonPic_PointerPressed&quot;&gt;
                    &lt;PersonPicture.ContextFlyout&gt;
                        &lt;MenuFlyout&gt;
                            &lt;MenuFlyoutItem Text=&quot;Settings&quot; /&gt;
                            &lt;MenuFlyoutSeparator /&gt;
                            &lt;MenuFlyoutItem Text=&quot;About Me&quot; /&gt;
                        &lt;/MenuFlyout&gt;
                    &lt;/PersonPicture.ContextFlyout&gt;
                &lt;/PersonPicture&gt;
            &lt;/StackPanel&gt;
        &lt;/Grid&gt;

        &lt;StackPanel
            Grid.Row=&quot;1&quot;
            HorizontalAlignment=&quot;Center&quot;
            VerticalAlignment=&quot;Center&quot;
            Orientation=&quot;Horizontal&quot;&gt;
            &lt;Button Click=&quot;myButton_Click&quot;&gt;Click Me&lt;/Button&gt;
        &lt;/StackPanel&gt;
    &lt;/Grid&gt;
&lt;/Window&gt;</x:String>
                    </local:CodeSource.Code>
                </local:CodeSource>
            </local:ControlExample.Xaml>

            <local:ControlExample.Cpp>
                <local:CodeSource>
                    <local:CodeSource.Code>
                        <x:String xml:space="preserve">CustomTitleBar::CustomTitleBar()
{
    ExtendsContentIntoTitleBar(true);
    AppWindow().TitleBar().PreferredHeightOption(winrt::Microsoft::UI::Windowing::TitleBarHeightOption::Tall);
}</x:String>
                    </local:CodeSource.Code>
                </local:CodeSource>
            </local:ControlExample.Cpp>
        </local:ControlExample>

    </StackPanel>
</Page>
