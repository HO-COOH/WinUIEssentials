<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3Example.FontIconExtensionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:WinUI3Example"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Style="{StaticResource ControlExamplesStackPanelStyle}">
        <InfoBar
            Title="Warning"
            IsClosable="False"
            IsOpen="True"
            Message="This FontIconExtension is mainly for porting controls from Community Toolkit, and I do NOT recommend you using this! Using a FontIcon is more explicit and will result in better performance." />

        <local:ControlExample HorizontalContentAlignment="Stretch" HeaderText="Without FontIconExtension">
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="Using FontIcon in Button:" />
                <Button>
                    <FontIcon Glyph="&#xE74F;" />
                </Button>

                <TextBlock Text="Using FontIcon in MenuFlyoutItem:" />
                <Button Content="Click to open menu">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Save">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74E;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Copy">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8C8;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Delete">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <TextBlock Text="Using FontIcon in NavigationViewItem:" />
                <NavigationView HorizontalAlignment="Stretch">
                    <NavigationView.MenuItems>
                        <NavigationViewItem Content="Email">
                            <NavigationViewItem.Icon>
                                <FontIcon Glyph="&#xE715;" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationView.MenuItems>
                </NavigationView>
            </StackPanel>

            <local:ControlExample.Xaml>
                <local:CodeSource>
                    <local:CodeSource.Code>
                        <x:String xml:space="preserve">&lt;Button&gt;
    &lt;FontIcon Glyph=&quot;&amp;#xE74F;&quot; /&gt;
&lt;/Button&gt;

&lt;Button Content=&quot;Click to open menu&quot;&gt;
    &lt;Button.Flyout&gt;
        &lt;MenuFlyout&gt;
            &lt;MenuFlyoutItem Text=&quot;Save&quot;&gt;
                &lt;MenuFlyoutItem.Icon&gt;
                    &lt;FontIcon Glyph=&quot;&amp;#xE74E;&quot; /&gt;
                &lt;/MenuFlyoutItem.Icon&gt;
            &lt;/MenuFlyoutItem&gt;
            &lt;MenuFlyoutItem Text=&quot;Copy&quot;&gt;
                &lt;MenuFlyoutItem.Icon&gt;
                    &lt;FontIcon Glyph=&quot;&amp;#xE8C8;&quot; /&gt;
                &lt;/MenuFlyoutItem.Icon&gt;
            &lt;/MenuFlyoutItem&gt;
            &lt;MenuFlyoutItem Text=&quot;Delete&quot;&gt;
                &lt;MenuFlyoutItem.Icon&gt;
                    &lt;FontIcon Glyph=&quot;&amp;#xE74D;&quot; /&gt;
                &lt;/MenuFlyoutItem.Icon&gt;
            &lt;/MenuFlyoutItem&gt;
        &lt;/MenuFlyout&gt;
    &lt;/Button.Flyout&gt;
&lt;/Button&gt;

&lt;NavigationView HorizontalAlignment=&quot;Stretch&quot;&gt;
    &lt;NavigationView.MenuItems&gt;
        &lt;NavigationViewItem Content=&quot;Email&quot;&gt;
            &lt;NavigationViewItem.Icon&gt;
                &lt;FontIcon Glyph=&quot;&amp;#xE715;&quot; /&gt;
            &lt;/NavigationViewItem.Icon&gt;
        &lt;/NavigationViewItem&gt;
    &lt;/NavigationView.MenuItems&gt;
&lt;/NavigationView&gt;</x:String>
                    </local:CodeSource.Code>
                </local:CodeSource>
            </local:ControlExample.Xaml>
        </local:ControlExample>

        <local:ControlExample HorizontalContentAlignment="Stretch" HeaderText="Using {essential:FontIcon} extension">
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="Using FontIcon in Button:" />
                <Button Content="{essential:FontIcon Glyph=&#xE74F;}" />

                <TextBlock Text="Using FontIcon in MenuFlyoutItem:" />
                <Button Content="Click to open menu">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Icon="{essential:FontIcon Glyph=&#xE74E;}" Text="Save" />
                            <MenuFlyoutItem Icon="{essential:FontIcon Glyph=&#xE8C8;}" Text="Copy" />
                            <MenuFlyoutItem Icon="{essential:FontIcon Glyph=&#xE74D;}" Text="Delete" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <TextBlock Text="Using FontIcon in NavigationViewItem:" />
                <NavigationView HorizontalAlignment="Stretch">
                    <NavigationView.MenuItems>
                        <NavigationViewItem Content="Email" Icon="{essential:FontIcon Glyph=&#xE715;}" />
                    </NavigationView.MenuItems>
                </NavigationView>
            </StackPanel>

            <local:ControlExample.Xaml>
                <local:CodeSource>
                    <local:CodeSource.Code>
                        <x:String xml:space="preserve">&lt;Button Content=&quot;{essential:FontIcon Glyph=&amp;#xE74F;}&quot; /&gt;

&lt;Button Content=&quot;Click to open menu&quot;&gt;
    &lt;Button.Flyout&gt;
        &lt;MenuFlyout&gt;
            &lt;MenuFlyoutItem Icon=&quot;{essential:FontIcon Glyph=&amp;#xE74E;}&quot; Text=&quot;Save&quot; /&gt;
            &lt;MenuFlyoutItem Icon=&quot;{essential:FontIcon Glyph=&amp;#xE8C8;}&quot; Text=&quot;Copy&quot; /&gt;
            &lt;MenuFlyoutItem Icon=&quot;{essential:FontIcon Glyph=&amp;#xE74D;}&quot; Text=&quot;Delete&quot; /&gt;
        &lt;/MenuFlyout&gt;
    &lt;/Button.Flyout&gt;
&lt;/Button&gt;

&lt;NavigationView HorizontalAlignment=&quot;Stretch&quot;&gt;
    &lt;NavigationView.MenuItems&gt;
        &lt;NavigationViewItem Content=&quot;Email&quot; Icon=&quot;{essential:FontIcon Glyph=&amp;#xE715;}&quot; /&gt;
    &lt;/NavigationView.MenuItems&gt;
&lt;/NavigationView&gt;</x:String>
                    </local:CodeSource.Code>
                </local:CodeSource>
            </local:ControlExample.Xaml>
        </local:ControlExample>

        <local:ControlExample HeaderText="You can also specify Fontsize, FontWeight, FontFamily, FontStyle and Foreground properties">
            <Button Content="{essential:FontIcon FontWeight=Bold, Foreground=Red, Glyph=&#x01FA;, FontFamily=Segoe Script}" />
            <local:ControlExample.Xaml>
                <local:CodeSource>
                    <local:CodeSource.Code>
                        <x:String xml:space="preserve">&lt;Button Content=&quot;{essential:FontIcon FontWeight=Bold, Foreground=Red, Glyph=&#x01FA;, FontFamily=Segoe Script}&quot; /&gt;</x:String>
                    </local:CodeSource.Code>
                </local:CodeSource>
            </local:ControlExample.Xaml>
        </local:ControlExample>
    </StackPanel>
</Page>
