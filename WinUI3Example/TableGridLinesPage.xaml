<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3Example.TableGridLinesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:WinUI3Example"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <local:ControlExample
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        HeaderText="Changing table grid lines">
        <local:ControlExample.Options>
            <StackPanel Spacing="8">
                <DropDownButton>
                    <StackPanel Spacing="4">
                        <TextBlock Text="HorizontalLineColor" />
                        <Rectangle
                            Height="40"
                            RadiusX="4"
                            RadiusY="4">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{x:Bind HorizontalLineColorPicker.Color, Mode=OneWay}" />
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <Flyout>
                            <ColorPicker
                                x:Name="HorizontalLineColorPicker"
                                IsAlphaEnabled="True"
                                IsAlphaSliderVisible="True" />
                        </Flyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <DropDownButton HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="4">
                        <TextBlock Text="VerticalLineColor" />
                        <Rectangle
                            Height="40"
                            RadiusX="4"
                            RadiusY="4">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{x:Bind VerticalLineColorPicker.Color, Mode=OneWay}" />
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <Flyout>
                            <ColorPicker
                                x:Name="VerticalLineColorPicker"
                                IsAlphaEnabled="True"
                                IsAlphaSliderVisible="True" />
                        </Flyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
        </local:ControlExample.Options>

        <essential:Table
            x:Name="DemoTable"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CornerRadius="{StaticResource ControlCornerRadius}"
            HeaderBackground="{ThemeResource ControlFillColorDefault}"
            HeaderFontWeight="Normal"
            HorizontalLineColor="{x:Bind HorizontalLineColorPicker.Color, Mode=OneWay}"
            VerticalLineColor="{x:Bind VerticalLineColorPicker.Color, Mode=OneWay}">
            <essential:Table.ItemsSource>
                <local:DemoTableData />
            </essential:Table.ItemsSource>
            <essential:Table.Columns>
                <essential:TableColumn Content="Id" />
                <essential:TableColumn Content="First Name" />
                <essential:TableColumn Content="Last Name" />
                <essential:TableColumn Content="Email" />
                <essential:TableColumn Content="Gender" />
                <essential:TableColumn Content="Dob" />
                <essential:TableColumn Content="Active At" />
                <essential:TableColumn Content="Is Active">
                    <essential:TableColumn.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Value, Mode=TwoWay}" />
                        </DataTemplate>
                    </essential:TableColumn.ItemTemplate>
                </essential:TableColumn>

                <essential:TableColumn Content="Department" />
                <essential:TableColumn Content="Designation" />
                <essential:TableColumn Content="Address">
                    <essential:TableColumn.EditTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBox Text="{x:Bind}" />
                        </DataTemplate>
                    </essential:TableColumn.EditTemplate>
                </essential:TableColumn>
            </essential:Table.Columns>
        </essential:Table>
    </local:ControlExample>
</Page>
