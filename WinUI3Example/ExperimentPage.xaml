<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3Example.ExperimentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:WinUI3Example"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Style="{StaticResource ControlExamplesStackPanelStyle}">
        <TextBlock Text="Experimental functionalities and application-specific functionalities that are not really applicable for every applications go here!" />

        <local:ControlExample HeaderText="Fully self-drawn transparent window demo">
            <Button x:Name="SelfDrawnWindowButton" Click="SelfDrawnWindowButton_Click">Click to show window</Button>
        </local:ControlExample>

        <local:ControlExample HeaderText="3D Flipping window">
            <Button x:Name="FlipWindowButton" Click="FlipWindowButton_Click">Click to create window</Button>
        </local:ControlExample>

        <local:ControlExample HeaderText="A Smooth morph animation that morph a Button to a ProgressBar">
            <Grid MinWidth="500">
                <Button x:Name="ButtonMorph" Style="{StaticResource AccentButtonStyle}">Click to morph</Button>
                <ProgressBar
                    x:Name="ProgressBarMorph"
                    Width="300"
                    Height="50"
                    Visibility="Collapsed"
                    Value="50" />
            </Grid>
            <local:ControlExample.Options>
                <StackPanel Spacing="5">
                    <Button Click="ButtonMorph_Click">Play animation at normal speed</Button>
                    <Button x:Name="SlowButtonMorph" Click="SlowButtonMorph_Click">Play animation 5x slower</Button>
                </StackPanel>
            </local:ControlExample.Options>
        </local:ControlExample>

        <local:ControlExample HeaderText="Animated digit">

            <StackPanel Orientation="Vertical" Spacing="8">
                <Slider
                    x:Name="AnimatedValue"
                    Width="500"
                    Maximum="300"
                    Minimum="0"
                    Value="50" />
                <local:AnimatedNumber FontSize="32" Value="{x:Bind essential:Convert.DoubleToInt32(AnimatedValue.Value), Mode=OneWay}" />

                <TextBlock Text="Current Time:" />
                <!--  Add a clock with HH:MM:SS using AnimatedNumber  -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <local:AnimatedNumber x:Name="HourNumber" FontSize="32" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="32"
                        Text=":" />
                    <local:AnimatedNumber x:Name="MinuteNumber" FontSize="32" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="32"
                        Text=":" />
                    <local:AnimatedNumber x:Name="SecondNumber" FontSize="32" />
                </StackPanel>
            </StackPanel>

        </local:ControlExample>

        <local:ControlExample HeaderText="AcrylicVisual">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Bottom" />
                        <Setter Property="HorizontalAlignment" Value="Right" />
                        <Setter Property="Margin" Value="8" />
                    </Style>
                    <Style TargetType="Grid">
                        <Setter Property="Width" Value="400" />
                        <Setter Property="Height" Value="200" />
                        <Setter Property="CornerRadius" Value="8" />
                    </Style>
                </StackPanel.Resources>
                <Grid>
                    <essential:AcrylicVisual />
                    <TextBlock Text="essential:AcrylicVisual" />
                </Grid>
                <Grid>
                    <essential:HostBackdropVisual />
                    <TextBlock Text="essential:HostBackdropVisual" />
                </Grid>
            </StackPanel>
        </local:ControlExample>

        <local:ControlExample HeaderText="LineGraph Demo">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <local:LineGraphControl x:Name="Graph">
                    <local:LineGraphControl.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.ThemeDictionaries>
                                <ResourceDictionary x:Key="Light">
                                    <SolidColorBrush x:Key="FillColor">#00ff00</SolidColorBrush>
                                </ResourceDictionary>
                            </ResourceDictionary.ThemeDictionaries>

                        </ResourceDictionary>

                    </local:LineGraphControl.Resources>
                </local:LineGraphControl>

                <StackPanel Grid.Row="1">
                    <Slider x:Name="ValueSlider" Maximum="500" />
                    <Button Click="AddValueButton_Click">Add</Button>
                </StackPanel>

            </Grid>
        </local:ControlExample>

        <local:ControlExample HeaderText="IconButton Demo">
            <local:ControlExample.Options>
                <ToggleSwitch x:Name="ExpandToggle" />
            </local:ControlExample.Options>

            <StackPanel
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Orientation="Vertical"
                Spacing="4">

                <local:IconButton
                    x:Name="NormalButton"
                    FontSize="20"
                    IsExpanded="{x:Bind ExpandToggle.IsOn, Mode=OneWay}">
                    <local:IconButton.Icon>
                        <FontIcon Glyph="&#xE700;" />
                    </local:IconButton.Icon>

                    <SymbolIcon Symbol="Accept" />

                    <local:IconButton.Container>
                        <Button x:Name="NormalInnerButton" Click="NormalInnerButton_Click" />
                    </local:IconButton.Container>
                </local:IconButton>

                <local:IconButton
                    x:Name="ToggleButton"
                    FontSize="20"
                    IsExpanded="{x:Bind ExpandToggle.IsOn, Mode=OneWay}">
                    <local:IconButton.Icon>
                        <FontIcon Glyph="&#xE700;" />
                    </local:IconButton.Icon>
                    Some content
                    <local:IconButton.Container>
                        <ToggleButton x:Name="ToggleInnerButton" Click="ToggleInnerButton_Click" />
                    </local:IconButton.Container>
                </local:IconButton>


                <local:IconButton
                    x:Name="HyperlinkButton"
                    FontSize="20"
                    IsExpanded="{x:Bind ExpandToggle.IsOn, Mode=OneWay}">
                    <local:IconButton.Icon>
                        <FontIcon Glyph="&#xE700;" />
                    </local:IconButton.Icon>

                    <TextBlock Text="https://www.google.com" TextDecorations="Underline" />
                    <local:IconButton.Container>
                        <HyperlinkButton NavigateUri="https://www.google.com" />
                    </local:IconButton.Container>
                </local:IconButton>
            </StackPanel>
        </local:ControlExample>

        <local:ControlExample HeaderText="DataGrid Demo">
            <local:DataGrid Width="500" Height="500" />
        </local:ControlExample>
    </StackPanel>
</Page>
