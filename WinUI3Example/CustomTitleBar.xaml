<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WinUI3Example.CustomTitleBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <essential:WindowCaptionButtonThemeWorkaround Window="{x:Bind}" />
        <Grid>
            <Grid.ColumnDefinitions>
                <!--  Left padding  -->
                <ColumnDefinition Width="10" />

                <!--  Icon column  -->
                <ColumnDefinition Width="Auto" />

                <!--  Title column  -->
                <ColumnDefinition Width="Auto" />

                <!--  drag area  -->
                <ColumnDefinition Width="*" />

                <!--  AutoSuggestBox column  -->
                <ColumnDefinition Width="4*" MinWidth="220" />

                <!--  drag area  -->
                <ColumnDefinition Width="*" MinWidth="48" />

                <!--  PersonPicture control  -->
                <ColumnDefinition Width="Auto" />

                <!--  drag area  -->
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <Image
                Grid.Column="1"
                Width="16"
                Height="16"
                Margin="8,0,16,0"
                Source="ms-appx:///Assets/StoreLogo.png" />
            <TextBlock
                Grid.Column="2"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="App title" />
            <AutoSuggestBox
                Grid.Column="4"
                MaxWidth="600"
                VerticalAlignment="Center"
                essential:WindowEx.NonClientRegionKind="Passthrough"
                PlaceholderText="Search"
                QueryIcon="Find" />
            <StackPanel
                Grid.Column="6"
                Margin="0,0,16,0"
                essential:WindowEx.NonClientRegionKind="Passthrough"
                Orientation="Horizontal"
                Spacing="10">
                <ToggleButton>Button on titlebar</ToggleButton>
                <PersonPicture Height="32" PointerPressed="PersonPic_PointerPressed">
                    <PersonPicture.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Settings" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="About Me" />
                        </MenuFlyout>
                    </PersonPicture.ContextFlyout>
                </PersonPicture>
            </StackPanel>
        </Grid>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Button Click="myButton_Click">Click Me</Button>
        </StackPanel>
    </Grid>
</Window>
